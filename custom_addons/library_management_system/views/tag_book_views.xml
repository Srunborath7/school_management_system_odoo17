<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_book_tag_tree" model="ir.ui.view">
        <field name="name">library.book.tag.tree</field>
        <field name="model">library.book.tag</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="remark"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_book_tag_form" model="ir.ui.view">
        <field name="name">library.book.tag.form</field>
        <field name="model">library.book.tag</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color_picker"/>
                        <field name="remark"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_book_tag" model="ir.actions.act_window">
        <field name="name">Book Tags</field>
        <field name="res_model">library.book.tag</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>