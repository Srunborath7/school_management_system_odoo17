<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_school_student_registry_tree" model="ir.ui.view">
        <field name="name">school.student.registry.tree</field>
        <field name="model">school.student.registry</field>
        <field name="arch" type="xml">
            <tree string="Students" decoration-info="status == 'graduated'" decoration-success="status == 'Enrolled'"
                  decoration-danger="status == 'cancelled'" decoration-warning="status == 'cancelled'">
                <field name="name"/>
                <field name="DOB"/>
                <field name="calc_age"/>
                <field name="course_ids"/>
                <field name="enrolled_date"/>
                <field name="status"/>
                <field name="create_uid"
       groups="school_management_system.group_school_management_admin"/>
            </tree>
        </field>
    </record>
    <record id="view_school_student_registry_form" model="ir.ui.view">
        <field name="name">school.student.registry.form</field>
        <field name="model">school.student.registry</field>
        <field name="arch" type="xml">
            <form string="Student">
                <header>
                    <button name="action_enroll" type="object" string="Enroll" class="oe_highlight" invisible="status != 'draft'"/>
                    <button name="action_graduate" type="object" string="Graduate" class="oe_highlight" invisible="status != 'enrolled'"/>
                    <button name="action_cancel" type="object" string="Cancel" class="btn-danger" invisible="status == 'cancelled'"/>
                    <button name="action_reset_draft" type="object" string="Reset to Draft" invisible="status != 'cancelled'"/>
                    <field name="status" widget="statusbar" statusbar_visible="draft,enrolled,graduated,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="DOB"/>
                        </group>
                        <group>
                            <field name="course_ids"/>
                            <field name="enrolled_date"/>
                            <field name="status"/>
                            <field name="create_uid"
                           groups="school_management_system.group_school_management_admin"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="message_ids"/>
                </div>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="view_school_student_registry_kanban" model="ir.ui.view">
        <field name="name">school.student.registry.kanban</field>
        <field name="model">school.student.registry</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status">
                <field name="name"/>
                <field name="DOB"/>
                <field name="course_ids"/>
                <field name="enrolled_date"/>
                <field name="calc_age"/>
                <field name="status"/>
                <field name="theme_primary"/>
                <field name="text_color_primary"/>
                <field name="theme_secondary"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click card border-0 shadow rounded-4 overflow-hidden">
                            <div class="card-header text-center py-3 rounded" t-attf-style="background: linear-gradient(135deg,#{record.theme_primary.raw_value},#{record.theme_secondary.raw_value});
                                    color: #{record.text_color_primary.raw_value};">
                                <i class="fa fa-users fa-3x mb-2" title="Users"/>
                                <h4 class="mb-0" t-attf-style="color:#{record.text_color_primary.raw_value}">
                                    <field name="name"/>
                                </h4>
                                <small>Student Profile</small>
                            </div>
                            <div class="card-body">
                                <div class="mb-2">
                                    <i class="fa fa-calendar text-primary me-2" title="Calendar"/>
                                    <strong>Date of Birth:</strong>
                                    <field name="DOB"/>
                                </div>
                                <div class="mb-2">
                                    <i class="fa fa-book me-2" title="Book"/>
                                    <strong>Course:</strong>
                                    <field name="course_ids"/>
                                </div>
                                <div class="mb-2">
                                    <i class="fa fa-calendar me-2" title="Calendar"/>
                                    <strong>Enrolled:</strong>
                                    <field name="enrolled_date"/>
                                </div>
                                <div class="mb-2">
                                    <i class="fa fa-calculator me-2" title="Calculate"/>
                                    <strong>Calculate Age:</strong>
                                    <field name="calc_age"/>
                                </div>
                                <hr/>
                                <div class="text-center">
                                    <strong>Status</strong>
                                    <div class="mt-2">
                                        <field name="status" widget="badge" decoration-muted="status == 'draft'"
                                               decoration-success="status == 'enrolled'"
                                               decoration-info="status == 'graduated'"
                                               decoration-danger="status == 'cancelled'"/>
                                    </div>
                                </div>
                            </div>
                            <div class="card-footer text-center bg-light">
                                <small class="text-muted">
                                    <i class="fa fa-graduation-cap me-1"/>
                                    School Management System
                                </small>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="view_school_student_registry_search" model="ir.ui.view">
        <field name="name">school.student.registry.search</field>
        <field name="model">school.student.registry</field>
        <field name="arch" type="xml">
            <search string="Search Students">
                <field name="name"/>
                <field name="course_ids"/>
                <field name="status"/>
                <filter string="Draft" name="draft" domain="[('status','=','draft')]"/>
                <filter string="Enrolled" name="enrolled" domain="[('status','=','enrolled')]"/>
                <filter string="Graduated" name="graduated" domain="[('status','=','graduated')]"/>
                <filter string="Cancelled" name="cancelled" domain="[('status','=','cancelled')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Course" name="group_course" context="{'group_by':'course_ids'}"/>
                    <filter string="Status" name="group_status" context="{'group_by':'status'}"/>
                </group>
                <searchpanel>
                    <field name="course_ids" string="Course" enable_counters="1"/>
                    <field name="status" string="Status" enable_counters="1"/>
                </searchpanel>
            </search>
        </field>
    </record>
    <record id="action_school_student_registry" model="ir.actions.act_window">
        <field name="name">Students Registry</field>
        <field name="res_model">school.student.registry</field>
        <field name="view_mode">tree,form,kanban</field>
    </record>
</odoo>