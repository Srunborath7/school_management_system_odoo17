<odoo>
    <record id="view_school_room_tree" model="ir.ui.view">
        <field name="name">school.room.tree</field>
        <field name="model">school.room</field>
        <field name="arch" type="xml">
            <tree string="Rooms">
                <field name="name"/>
                <field name="room_type_id"/>
                <field name="floor"/>
                <field name="building"/>
                <field name="capacity"/>
                <field name="status"/>
            </tree>
        </field>
    </record>
    <record id="view_school_room_form" model="ir.ui.view">
        <field name="name">school.room.form</field>
        <field name="model">school.room</field>
        <field name="arch" type="xml">
            <form string="Room">
                <header>
                    <button name="action_open_room_type_modal"
                            type="object"
                            string="Create Room Type"
                            class="btn-primary"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Room Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Room Details">
                            <field name="room_type_id"/>
                            <field name="capacity"/>
                            <field name="status"/>
                        </group>

                        <group string="Location">
                            <field name="floor"/>
                            <field name="building"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>

                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    <record id="action_school_room" model="ir.actions.act_window">
        <field name="name">Rooms</field>
        <field name="res_model">school.room</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>