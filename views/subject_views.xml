<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_school_subjects_tree" model="ir.ui.view">
        <field name="name">school.subject.tree</field>
        <field name="model">school.subject</field>
        <field name="arch" type="xml">
            <tree string="Subjects">
                <field name="name"/>
                <field name="time_duration"/>
                <field name="teacher_ids"/>
                <field name="class_room_ids"/>
                <field name="status"/>
            </tree>
        </field>
    </record>
    <record id="view_school_subjects_form" model="ir.ui.view">
        <field name="name">school.subject.form</field>
        <field name="model">school.subject</field>
        <field name="arch" type="xml">

            <form string="Subject">

                <header>
                    <button name="action_active" type="object"
                            string="Activate"
                            class="oe_highlight"
                            invisible="status != 'draft'"/>

                    <button name="action_completed" type="object"
                            string="Complete"
                            class="oe_highlight"
                            invisible="status != 'active'"/>

                    <button name="action_inactive" type="object"
                            string="Deactivate"
                            invisible="status in ('inactive', 'completed')"/>

                    <button name="action_reset_draft" type="object"
                            string="Reset"
                            invisible="status == 'draft'"/>

                    <field name="status"
                           widget="statusbar"
                           statusbar_visible="draft,active,inactive,completed"/>
                </header>

                <sheet>
                    <group>

                        <field name="name"/>
                        <field name="time_duration"/>

                        <!-- ✔ SAFE for form view -->
                        <field name="teacher_ids" widget="many2many_tags"/>
                        <field name="class_room_ids" widget="many2many_tags"/>

                        <field name="description"/>

                    </group>
                </sheet>

                <!-- Chatter -->
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>

            </form>

        </field>
    </record>
    <record id="view_school_subjects_kanban" model="ir.ui.view">
        <field name="name">school.subject.kanban</field>
        <field name="model">school.subject</field>
        <field name="arch" type="xml">
            <kanban default_group_by="class_room_ids">
                <field name="name"/>
                <field name="time_duration"/>
                <field name="teacher_ids" widget="many2many_tags"/>
                <field name="class_room_ids" widget="many2many_tags"/>
                <field name="description"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click card border-0 shadow rounded-4 overflow-hidden">
                            <div class="card-header text-center text-white py-4"
                                 style="background: linear-gradient(135deg,#2d358e,#4f5bd5);border-radius: 24px 24px 0 0;box-shadow: 0 4px 12px rgba(0,0,0,.15);">
                                <i class="fa fa-book fa-3x mb-2" title="Book"/>
                                <h4 class="mb-0 fw-bold text-white">
                                    <field name="name"/>
                                </h4>
                                <small class="opacity-75">
                                    Course Information
                                </small>
                            </div>
                            <div class="card-body">
                                <div class="mb-3 text-end text-white">
                                    <span class="badge rounded-pill bg-primary fs-6 px-3 py-2">
                                        <i class="fa fa-clock-o me-1" title="Clock"/>
                                        <field name="time_duration"/>
                                    </span>
                                </div>
                                <div class="mb-2">
                                    <i class="fa fa-graduation-cap text-primary me-2" title="Calendar"/>
                                    <strong>Teacher:</strong>
                                    <field name="teacher_ids"/>
                                </div>
                                <div class="mb-2">
                                    <i class="fa fa-building text-primary me-2" title="Calendar"/>
                                    <strong>Room:</strong>
                                    <field name="class_room_ids"/>
                                </div>
                                <hr class="my-3"/>
                                <div class="mt-3">
                                    <i class="fa fa-quote-left text-primary me-2" title="quote"/>
                                    <strong>Description</strong>

                                    <blockquote class="blockquote mt-2 ps-3 border-start">
                                        <field name="description"/>
                                    </blockquote>
                                </div>
                            </div>
                            <div class="card-footer bg-light text-center">
                                <small class="text-muted">
                                    <i class="fa fa-graduation-cap me-1" title="Graduation"/>
                                    School Management System
                                </small>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="action_school_subjects" model="ir.actions.act_window">
        <field name="name">Subject</field>
        <field name="res_model">school.subject</field>
        <field name="view_mode">tree,form,kanban</field>
    </record>

</odoo>