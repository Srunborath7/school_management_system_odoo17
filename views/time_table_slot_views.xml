<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_timetable_slot_tree" model="ir.ui.view">
        <field name="name">school.timetable.slot.tree</field>
        <field name="model">school.timetable.slot</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="day_of_week"/>
                <field name="start_time"/>
                <field name="end_time"/>
                <field name="class_id"/>
                <field name="subject_id"/>
                <field name="teacher_id"/>
                <field name="color" optional="1"/>
            </tree>
        </field>
    </record>

    <record id="view_timetable_slot_form" model="ir.ui.view">
        <field name="name">school.timetable.slot.form</field>
        <field name="model">school.timetable.slot</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="day_of_week" placeholder="select day..."/>
                    </group>
                    <group>
                        <field name="start_time" placeholder="Select start time..."/>
                        <field name="end_time" placeholder="Select end time..."/>
                        <field name="duration" readonly="1"/>
                    </group>
                    <group string="Academic Info">
                        <field name="academic_year_id" placeholder="Select academic year..."/>
                        <field name="program_id" placeholder="Select academic program..."/>
                        <field name="class_id" placeholder="Select class..."/>
                    </group>
                    <group string="Schedule Info">
                        <field name="subject_id" placeholder="Select subject..."/>
                        <field name="teacher_id" placeholder="Select teacher..."/>
                    </group>
                    <group>
                        <field name="is_active"/>
                        <field name="color" widget="color_picker"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_timetable_slot_calendar" model="ir.ui.view">
        <field name="name">school.timetable.slot.calendar</field>
        <field name="model">school.timetable.slot</field>
        <field name="arch" type="xml">
            <calendar string="Class Timetable" date_start="start_time" date_stop="end_time" color="color" mode="week" event_open_popup="true">
                <field name="name"/>
                <field name="subject_id"/>
                <field name="teacher_id"/>
                <field name="class_id"/>
            </calendar>
        </field>
    </record>

    <record id="action_timetable_slot" model="ir.actions.act_window">
        <field name="name">Timetable Slots</field>
        <field name="res_model">school.timetable.slot</field>
        <field name="view_mode">calendar,tree,form</field>
    </record>
</odoo>