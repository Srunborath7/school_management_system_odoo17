#. module: delivery_ups
#. odoo-python
#: code:addons/delivery_ups/models/ups_request.py:0
#, python-format
msgid "A shipment cannot have a KGS/IN or LBS/CM as its unit of measurements. Configure it from the delivery method."
msgstr ""
"ການສົ່ງສິນຄ້າບໍ່ສາມາດໃຊ້ KGS/IN ຫຼື LBS/CM ເປັນຫົວໜ່ວຍວັດແທກໄດ້. ກະລຸນາຕັ້ງຄ່າຄືນໃໝ່ໃນວິທີການຈັດສົ່ງ."

#. module: delivery_ups
#. odoo-python
#: code:addons/delivery_ups/models/ups_request.py:0
#, python-format
msgid "Access License number is Invalid. Provide a valid number (Length should be 0-35 alphanumeric characters)"
msgstr ""
"ໝາຍເລກອະນຸຍາດເຂົ້າໃຊ້ບໍ່ຖືກຕ້ອງ. ກະລຸນາລະບຸໝາຍເລກທີ່ຖືກຕ້ອງ (ຄວາມຍາວລະຫວ່າງ 0-35 ຕົວອັກສອນ ຫຼື ຕົ"
"ວເລກ)"

#. module: delivery_ups
#. odoo-python
#: code:addons/delivery_ups/models/ups_request.py:0
#, python-format
msgid "Access License number is invalid for this delivery provider."
msgstr "ໝາຍເລກອະນຸຍາດເຂົ້າໃຊ້ບໍ່ຖືກຕ້ອງ ສຳລັບຜູ້ໃຫ້ບໍລິການຈັດສົ່ງນີ້."

#. module: delivery_ups
#. odoo-python
#: code:addons/delivery_ups/models/ups_request.py:0
#, python-format
