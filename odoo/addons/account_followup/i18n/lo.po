#. module: account_followup
#: model:mail.template,body_html:account_followup.email_template_followup_1
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                    <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"                        <t t-if=\"object.id != object.commercial_partner_id.id\">Dear <t t-out=\"object.name or ''\"></t> (<t t-out=\"object.commercial_partner_id.name or ''\"></t>),</t>\n"
"                        <t t-else=\"\">Dear <t t-out=\"object.name or ''\"></t>,</t>\n"
"                        <br>\n"
"                    </p>\n"
"                    <p>\n"
"                        It has come to our attention that you have an outstanding balance of <t t-out=\"format_amount(object.total_overdue, object.currency_id) or ''\"></t>\n"
"                        <br>\n"
"                    </p>\n"
"                    <p>\n"
"                        We kindly request that you take necessary action to settle this amount within the next 8 days.\n"
"                    </p>\n"
"                    <p>\n"
"                        If you have already made the payment after receiving this message, please disregard it.\n"
"                        Our accounting department is available if you require any assistance or have any questions.\n"
"                        <br>\n"
"                    </p>\n"
"                    <p>\n"
"                        Thank you for your cooperation.\n"
"                        <br>\n"
"                    </p>\n"
"                    <p>\n"
"                        Sincerely,\n"
"                        <t t-if=\"not is_html_empty(object._get_followup_responsible().signature)\">\n"
"                            <br>\n"
"                            <t t-out=\"object._get_followup_responsible().signature\"></t>\n"
"                        </t>\n"
"                        <t t-else=\"\">\n"
"                            <br>\n"
"                            --\n"
"                            <br>\n"
"                            <t t-out=\"object._get_followup_responsible().name\"></t>\n"
"                        </t>\n"
"                    </p>\n"
"                </div>\n"
"            "
msgstr ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                    <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">"
"\n"
"                        <t t-if=\"object.id != "
"object.commercial_partner_id.id\">ຮຽນ <t t-out=\"object.name or ''\"></t> "
"(<t t-out=\"object.commercial_partner_id.name or ''\"></t>),</t>\n"
"                        <t t-else=\"\">ຮຽນ <t t-out=\"object.name or ''\"></"
"t>,</t>\n"
"                        <br>\n"
"                    </p>\n"
"                    <p>\n"
"                        ພວກເຮົາຂໍແຈ້ງໃຫ້ທ່ານຊາບວ່າ ທ່ານມີຍອດຄ້າງຊຳລະຈຳນວນ <t t-"
"out=\"format_amount(object.total_overdue, object.currency_id) or ''\"></t>\n"
"                        <br>\n"
"                    </p>\n"
"                    <p>\n"
"                        ພວກເຮົາຂໍຄວາມຮ່ວມມືໃຫ້ທ່ານດຳເນີນການຊຳລະຍອດດັ່ງກ່າວພາຍໃນ 8 ວັນຕໍ່ໜ້າ"
"ນີ້.\n"
"                    </p>\n"
"                    <p>\n"
"                        ຫາກທ່ານໄດ້ດຳເນີນການຊຳລະແລ້ວກ່ອນໄດ້ຮັບຂໍ້ຄວາມນີ້, ກະລຸນາຂ້າມຂໍ້ຄວາມນີ້ໄ"
"ປ.\n"
"                        ພະແນກບັນຊີຂອງພວກເຮົາຍິນດີໃຫ້ຄວາມຊ່ວຍເຫຼືອ ຫາກທ່ານມີຄຳຖາມ ຫຼື ຕ້ອງກາ"
"ນຂໍ້ມູນເພີ່ມເຕີມ.\n"
"                        <br>\n"
"                    </p>\n"
"                    <p>\n"
"                        ຂໍຂອບໃຈໃນຄວາມຮ່ວມມື.\n"
"                        <br>\n"
"                    </p>\n"
"                    <p>\n"
"                        ດ້ວຍຄວາມນັບຖື,\n"
"                        <t t-if=\"not is_html_empty"
"(object._get_followup_responsible().signature)\">\n"
"                            <br>\n"
"                            <t t-out=\"object._get_followup_responsible()"
".signature\"></t>\n"
"                        </t>\n"
"                        <t t-else=\"\">\n"
"                            <br>\n"
"                            --\n"
"                            <br>\n"
"                            <t t-out=\"object._get_followup_responsible()"
".name\"></t>\n"
"                        </t>\n"
"                    </p>\n"
"                </div>\n"
"            "

#. module: account_followup
#: model:mail.template,body_html:account_followup.demo_followup_email_template_4
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                    <p>\n"
"                        <t t-if=\"object.id != object.commercial_partner_id.id\">Dear <t t-out=\"object.name or ''\"></t> (<t t-out=\"object.commercial_partner_id.name or ''\"></t>),</t>\n"
"                        <t t-else=\"\">Dear <t t-out=\"object.name or ''\"></t>,</t>\n"
"                        <br>\n"
"                    </p>\n"
"                    <p>\n"
"                        Despite several reminders, your account is still not settled.\n"
"                        Unless full payment is made in next 8 days, then legal action for the recovery of the debt will be taken without further notice.\n"
"                        I trust that this action will prove unnecessary and details of due payments is printed below.\n"
"                        In case of any queries concerning this matter, do not hesitate to contact our accounting department.\n"
"                    </p>\n"
"                    <p>\n"
"                        Best Regards,\n"
"                        <t t-if=\"not is_html_empty(object._get_followup_responsible().signature)\">\n"
"                            <br>\n"
"                            <t t-out=\"object._get_followup_responsible().signature\"></t>\n"
"                        </t>\n"
"                        <t t-else=\"\">\n"
"                            <br>\n"
"                            --\n"
"                            <br>\n"
"                            <t t-out=\"object._get_followup_responsible().name\"></t>\n"
"                        </t>\n"
"                    </p>\n"
"                </div>\n"
"            "
msgstr ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                    <p>\n"
"                        <t t-if=\"object.id != "
"object.commercial_partner_id.id\">ຮຽນ <t t-out=\"object.name or ''\"></t> "
"(<t t-out=\"object.commercial_partner_id.name or ''\"></t>),</t>\n"
"                        <t t-else=\"\">ຮຽນ <t t-out=\"object.name or ''\"></"
"t>,</t>\n"
"                        <br>\n"
"                    </p>\n"
"                    <p>\n"
"                        ເຖິງວ່າຈະມີການແຈ້ງເຕືອນຫຼາຍຄັ້ງແລ້ວ, ແຕ່ບັນຊີຂອງທ່ານຍັງບໍ່ທັນໄດ້ຮັບການຊຳ"
"ລະ.\n"
"                        ຫາກບໍ່ມີການຊຳລະເຕັມຈຳນວນພາຍໃນ 8 ວັນຕໍ່ໜ້ານີ້, ພວກເຮົາຈະດຳເນີນຄະດີຕ"
"າມກົດໝາຍເພື່ອທວງຖາມໜີ້ສິນໂດຍບໍ່ມີການແຈ້ງໃຫ້ຊາບຕື່ມອີກ.\n"
"                        ພວກເຮົາຫວັງວ່າການດຳເນີນການດັ່ງກ່າວຈະບໍ່ມີຄວາມຈຳເປັນ. ລາຍລະອຽດຂອງ"
"ການຊຳລະທີ່ຄ້າງຢູ່ແມ່ນໄດ້ລະບຸໄວ້ຂ້າງລຸ່ມນີ້.\n"
"                        ຫາກທ່ານມີຂໍ້ສົງໄສກ່ຽວກັບເລື່ອງນີ້, ກະລຸນາຕິດຕໍ່ພະແນກບັນຊີຂອງພວກເຮົາໂດຍດ່"
"ວນ.\n"
"                    </p>\n"
"                    <p>\n"
"                        ດ້ວຍຄວາມນັບຖື,\n"
"                        <t t-if=\"not is_html_empty"
"(object._get_followup_responsible().signature)\">\n"
"                            <br>\n"
"                            <t t-out=\"object._get_followup_responsible()"
".signature\"></t>\n"
"                        </t>\n"
"                        <t t-else=\"\">\n"
"                            <br>\n"
"                            --\n"
"                            <br>\n"
"                            <t t-out=\"object._get_followup_responsible()"
".name\"></t>\n"
"                        </t>\n"
"                    </p>\n"
"                </div>\n"
"            "

#. module: account_followup
#: model:mail.template,body_html:account_followup.demo_followup_email_template_2
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                    <p>\n"
"                        <t t-if=\"object.id != object.commercial_partner_id.id\">Dear <t t-out=\"object.name or ''\"></t> (<t t-out=\"object.commercial_partner_id.name or ''\"></t>),</t>\n"
"                        <t t-else=\"\">Dear <t t-out=\"object.name or ''\"></t>,</t>\n"
"                        <br>\n"
"                    </p>\n"
"                    <p>\n"
"                        We are disappointed to see that despite sending a reminder, that your account is now seriously overdue.\n"
"                    </p>\n"
"                    <p>\n"
"                        It is essential that immediate payment is made, otherwise we will have to consider placing a stop on your account which means that we will no longer be able to supply your company with (goods/services).\n"
"                        Please, take appropriate measures in order to carry out this payment in the next 8 days.\n"
"                    </p>\n"
"                    <p>\n"
"                        If there is a problem with paying invoice that we are not aware of, do not hesitate to contact our accounting department, so that we can resolve the matter quickly.\n"
"                    </p>\n"
"                    <p>\n"
"                        Details of due payments is printed below.\n"
"                    </p>\n"
"                    <p>\n"
"                        Best Regards,\n"
"                        <t t-if=\"not is_html_empty(object._get_followup_responsible().signature)\">\n"
"                            <br>\n"
"                            <t t-out=\"object._get_followup_responsible().signature\"></t>\n"
"                        </t>\n"
"                        <t t-else=\"\">\n"
"                            <br>\n"
"                            --\n"
"                            <br>\n"
"                            <t t-out=\"object._get_followup_responsible().name\"></t>\n"
"                        </t>\n"
"                    </p>\n"
"                </div>\n"
"            "
msgstr ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                    <p>\n"
"                        <t t-if=\"object.id != "
"object.commercial_partner_id.id\">ຮຽນ <t t-out=\"object.name or ''\"></t> "
"(<t t-out=\"object.commercial_partner_id.name or ''\"></t>),</t>\n"
"                        <t t-else=\"\">ຮຽນ <t t-out=\"object.name or ''\"></"
"t>,</t>\n"
"                        <br>\n"
"                    </p>\n"
"                    <p>\n"
"                        ພວກເຮົາຮູ້ສຶກເສຍໃຈທີ່ເຫັນວ່າ ເຖິງແມ່ນວ່າຈະມີການສົ່ງໜັງສືແຈ້ງເຕືອນໄປແລ້"
"ວ, ແຕ່ບັນຊີຂອງທ່ານໃນເວລານີ້ແມ່ນມີການຄ້າງຊຳລະເກີນກຳນົດຢ່າງໜັກໜ່ວງ.\n"
"                    </p>\n"
"                    <p>\n"
"                        ມັນເປັນສິ່ງຈຳເປັນທີ່ທ່ານຕ້ອງໄດ້ຊຳລະເງິນໂດຍດ່ວນ, ຖ້າບໍ່ດັ່ງນັ້ນ ພວກເຮົາຈຳເ"
"ປັນຕ້ອງໄດ້ພິຈາລະນາລະງັບບັນຊີຂອງທ່ານ ຊຶ່ງໝາຍຄວາມວ່າ ພວກເຮົາຈະບໍ່ສາມາດສະໜອງ (ສິນຄ້າ/ບໍລິການ) ໃຫ້ແກ່"
"ບໍລິສັດຂອງທ່ານໄດ້ອີກຕໍ່ໄປ.\n"
"                        ກະລຸນາດຳເນີນການຕາມຂັ້ນຕອນທີ່ເໝາະສົມ ເພື່ອຊຳລະເງິນໃຫ້ສຳເລັດພາຍໃນ "
"8 ວັນຕໍ່ໜ້າ.\n"
"                    </p>\n"
"                    <p>\n"
"                        ຫາກມີບັນຫາໃດໆກ່ຽວກັບການຊຳລະໃບແຈ້ງໜີ້ທີ່ພວກເຮົາບໍ່ທັນຊາບ, ກະລຸນາຕິດຕໍ່ພ"
