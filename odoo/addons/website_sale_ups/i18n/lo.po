#: model_terms:payment.provider,auth_msg:website_sale_ups.payment_provider_ups_cod
msgid "Your payment has been authorized."
msgstr "ການຊຳລະເງິນຂອງທ່ານໄດ້ຮັບອະນຸຍາດແລ້ວ."

#. module: website_sale_ups
