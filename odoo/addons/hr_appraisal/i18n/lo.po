"8px 16px 8px 16px; background-color: #F1F1F1;\">\n"
"                                <t t-out=\"ctx.get('user_body')\">ການປະເມີນຜົນປ"
"ະຈຳປີ.</t>\n"
"                            </div>\n"
"                        </t>\n"
"                        <t t-if=\"ctx.get('recipient_users')\">\n"
"                            <p style=\"margin: 16px 0px 16px 0px; padding: "
"8px 16px 8px 16px; text-align: center;\">\n"
"                                <a t-att-t-att-href=\"ctx.get('url')\" "
"style=\" margin: auto; background-color:#875A7B; padding: 8px 16px 8px 16px; "
"text-decoration: none; color: #fff; border-radius: 5px;\">\n"
"                                    ເບິ່ງການປະເມີນຜົນ\n"
"                                </a>\n"
"                            </p>\n"
"                        </t>\n"
"                    </p>\n"
"                </div>\n"
"            "

